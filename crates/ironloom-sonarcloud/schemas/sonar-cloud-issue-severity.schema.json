{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SonarCloudIssueSeverity",
  "description": "Normalized SonarCloud issue severity.",
  "oneOf": [
    {
      "description": "Blocking severity.",
      "type": "string",
      "const": "blocker"
    },
    {
      "description": "Critical severity.",
      "type": "string",
      "const": "critical"
    },
    {
      "description": "Major severity.",
      "type": "string",
      "const": "major"
    },
    {
      "description": "Minor severity.",
      "type": "string",
      "const": "minor"
    },
    {
      "description": "Informational severity.",
      "type": "string",
      "const": "info"
    },
    {
      "description": "Unrecognized severity.",
      "type": "string",
      "const": "unknown"
    }
  ]
}
