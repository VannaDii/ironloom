{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CheckRunProjection",
  "description": "Source-of-truth GitHub check-run projection.",
  "type": "object",
  "properties": {
    "conclusion": {
      "description": "Normalized check-run conclusion when GitHub has one.",
      "anyOf": [
        {
          "$ref": "#/$defs/CheckRunConclusion"
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "description": "Check-run name.",
      "type": "string"
    },
    "source_of_truth": {
      "description": "Whether the value came directly from GitHub instead of local cache.",
      "type": "boolean"
    },
    "status": {
      "description": "Normalized check-run status.",
      "$ref": "#/$defs/CheckRunStatus"
    }
  },
  "required": [
    "name",
    "status",
    "source_of_truth"
  ],
  "$defs": {
    "CheckRunConclusion": {
      "description": "Normalized GitHub check-run conclusion.",
      "oneOf": [
        {
          "description": "Check run succeeded.",
          "type": "string",
          "const": "success"
        },
        {
          "description": "Check run failed.",
          "type": "string",
          "const": "failure"
        },
        {
          "description": "Check run was cancelled.",
          "type": "string",
          "const": "cancelled"
        },
        {
          "description": "Check run was skipped.",
          "type": "string",
          "const": "skipped"
        },
        {
          "description": "Check run timed out.",
          "type": "string",
          "const": "timed_out"
        },
        {
          "description": "Check run requires action.",
          "type": "string",
          "const": "action_required"
        },
        {
          "description": "Check run completed neutrally.",
          "type": "string",
          "const": "neutral"
        },
        {
          "description": "Check run is stale.",
          "type": "string",
          "const": "stale"
        },
        {
          "description": "GitHub returned an unrecognized conclusion.",
          "type": "string",
          "const": "unknown"
        }
      ]
    },
    "CheckRunStatus": {
      "description": "Normalized GitHub check-run status.",
      "oneOf": [
        {
          "description": "Check run is queued.",
          "type": "string",
          "const": "queued"
        },
        {
          "description": "Check run is running.",
          "type": "string",
          "const": "in_progress"
        },
        {
          "description": "Check run completed.",
          "type": "string",
          "const": "completed"
        },
        {
          "description": "GitHub returned an unrecognized status.",
          "type": "string",
          "const": "unknown"
        }
      ]
    }
  }
}
