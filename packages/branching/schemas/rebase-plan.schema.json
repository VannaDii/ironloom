{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/RebasePlan",
  "definitions": {
    "RebasePlan": {
      "type": "object",
      "properties": {
        "mergedPrNumber": {
          "type": "number"
        },
        "baseBranch": {
          "type": "string"
        },
        "dependentBranches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rebaseRequired": {
          "type": "boolean"
        },
        "conflictsExpected": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string"
        },
        "dependencyGraph": {
          "type": "object",
          "properties": {
            "baseBranch": {
              "type": "string"
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fromBranch": {
                    "type": "string"
                  },
                  "toBranch": {
                    "type": "string"
                  }
                },
                "required": ["fromBranch", "toBranch"],
                "additionalProperties": false
              }
            }
          },
          "required": ["baseBranch", "edges"],
          "additionalProperties": false
        },
        "conflictClassification": {
          "type": "object",
          "properties": {
            "kind": {
              "enum": ["none", "expected", "detected"]
            },
            "affectedBranches": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nextAction": {
              "type": "string"
            }
          },
          "required": ["kind", "affectedBranches", "nextAction"],
          "additionalProperties": false
        }
      },
      "required": [
        "mergedPrNumber",
        "baseBranch",
        "dependentBranches",
        "rebaseRequired",
        "conflictsExpected",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
