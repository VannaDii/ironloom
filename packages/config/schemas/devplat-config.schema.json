{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DevplatConfig",
  "definitions": {
    "DevplatConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "githubOwner": {
          "type": "string"
        },
        "githubRepo": {
          "type": "string"
        },
        "repository": {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "defaultBranch": {
              "type": "string"
            },
            "repositoryKey": {
              "type": "string"
            }
          },
          "required": ["owner", "repo", "defaultBranch", "repositoryKey"],
          "additionalProperties": false
        },
        "storage": {
          "type": "object",
          "properties": {
            "rootDirectory": {
              "type": "string"
            },
            "layoutVersion": {
              "const": 1
            }
          },
          "required": ["rootDirectory", "layoutVersion"],
          "additionalProperties": false
        },
        "worktrees": {
          "type": "object",
          "properties": {
            "rootDirectory": {
              "type": "string"
            },
            "baseBranch": {
              "type": "string"
            }
          },
          "required": ["rootDirectory", "baseBranch"],
          "additionalProperties": false
        },
        "discord": {
          "type": "object",
          "properties": {
            "apiBaseUrl": {
              "type": "string"
            },
            "apiVersion": {
              "const": "v10"
            },
            "applicationId": {
              "type": "string"
            },
            "publicKey": {
              "type": "string"
            },
            "botToken": {
              "type": "string"
            },
            "installScopes": {
              "type": "array",
              "items": {
                "enum": ["bot", "applications.commands"]
              }
            },
            "requiredPermissions": {
              "type": "array",
              "items": {
                "enum": [
                  "ViewChannel",
                  "SendMessages",
                  "CreatePublicThreads",
                  "CreatePrivateThreads",
                  "SendMessagesInThreads",
                  "ManageThreads",
                  "ReadMessageHistory"
                ]
              }
            },
            "defaultGuildId": {
              "type": "string"
            },
            "specChannelId": {
              "type": "string"
            },
            "implementationChannelId": {
              "type": "string"
            },
            "pullRequestChannelId": {
              "type": "string"
            },
            "auditChannelId": {
              "type": "string"
            },
            "projectManagementChannelId": {
              "type": "string"
            },
            "threadBindingMode": {
              "const": "inherit-parent"
            }
          },
          "required": [
            "apiBaseUrl",
            "apiVersion",
            "applicationId",
            "publicKey",
            "botToken",
            "installScopes",
            "requiredPermissions",
            "defaultGuildId",
            "specChannelId",
            "implementationChannelId",
            "pullRequestChannelId",
            "auditChannelId",
            "projectManagementChannelId",
            "threadBindingMode"
          ],
          "additionalProperties": false
        },
        "openclaw": {
          "type": "object",
          "properties": {
            "pluginId": {
              "type": "string"
            },
            "gateway": {
              "type": "object",
              "properties": {
                "bind": {
                  "const": "loopback"
                },
                "port": {
                  "type": "number"
                },
                "authMode": {
                  "const": "token"
                }
              },
              "required": ["bind", "port", "authMode"],
              "additionalProperties": false
            },
            "actionGates": {
              "type": "object",
              "properties": {
                "approveThis": {
                  "type": "boolean"
                },
                "mergeNow": {
                  "type": "boolean"
                },
                "retryGates": {
                  "type": "boolean"
                },
                "rebaseAllDependents": {
                  "type": "boolean"
                }
              },
              "required": [
                "approveThis",
                "mergeNow",
                "retryGates",
                "rebaseAllDependents"
              ],
              "additionalProperties": false
            }
          },
          "required": ["pluginId", "gateway", "actionGates"],
          "additionalProperties": false
        },
        "sonar": {
          "type": "object",
          "properties": {
            "organization": {
              "type": "string"
            },
            "projectKey": {
              "type": "string"
            },
            "minimumCoverage": {
              "const": 90
            }
          },
          "required": ["organization", "projectKey", "minimumCoverage"],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "githubOwner",
        "githubRepo",
        "repository",
        "storage",
        "worktrees",
        "discord",
        "openclaw",
        "sonar"
      ],
      "additionalProperties": false
    }
  }
}
