{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ArtifactRegistry",
  "definitions": {
    "ArtifactRegistry": {
      "type": "object",
      "properties": {
        "registryId": {
          "type": "string"
        },
        "version": {
          "const": 1
        },
        "repositoryKey": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifactType": {
                "enum": [
                  "approval-record",
                  "audit-log",
                  "gate-run-report",
                  "merge-decision",
                  "pull-request-record",
                  "rebase-result",
                  "remediation-plan",
                  "research-brief",
                  "review-finding",
                  "slice-plan",
                  "spec-record",
                  "task-record",
                  "telemetry-event",
                  "worktree-allocation"
                ]
              },
              "currentVersion": {
                "type": "number"
              },
              "schemaName": {
                "type": "string"
              },
              "ownerPackage": {
                "type": "string"
              },
              "storageScope": {
                "enum": [
                  "artifacts",
                  "audit",
                  "gates",
                  "memory",
                  "pull-requests",
                  "remediation",
                  "reviews",
                  "slices",
                  "specs",
                  "state",
                  "tasks",
                  "telemetry",
                  "worktrees"
                ]
              },
              "migrationPolicy": {
                "enum": ["none", "optional", "required"]
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              },
              "description": {
                "type": "string"
              }
            },
            "required": [
              "artifactType",
              "currentVersion",
              "schemaName",
              "ownerPackage",
              "storageScope",
              "migrationPolicy",
              "updatedAt"
            ],
            "additionalProperties": false
          }
        },
        "migrations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "migrationId": {
                "type": "string"
              },
              "artifactType": {
                "enum": [
                  "approval-record",
                  "audit-log",
                  "gate-run-report",
                  "merge-decision",
                  "pull-request-record",
                  "rebase-result",
                  "remediation-plan",
                  "research-brief",
                  "review-finding",
                  "slice-plan",
                  "spec-record",
                  "task-record",
                  "telemetry-event",
                  "worktree-allocation"
                ]
              },
              "fromVersion": {
                "type": "number"
              },
              "toVersion": {
                "type": "number"
              },
              "summary": {
                "type": "string"
              },
              "migratedAt": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": [
              "migrationId",
              "artifactType",
              "fromVersion",
              "toVersion",
              "summary",
              "migratedAt"
            ],
            "additionalProperties": false
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "registryId",
        "version",
        "repositoryKey",
        "entries",
        "migrations",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
