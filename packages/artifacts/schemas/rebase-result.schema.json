{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/RebaseResultArtifact",
  "definitions": {
    "RebaseResultArtifact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "const": "rebase-result"
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "properties": {
            "resultId": {
              "type": "string"
            },
            "mergedPrNumber": {
              "type": "number"
            },
            "baseBranch": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "branchName": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "rebased": {
              "type": "boolean"
            },
            "conflictsDetected": {
              "type": "boolean"
            },
            "details": {
              "type": "string"
            }
          },
          "required": [
            "resultId",
            "mergedPrNumber",
            "baseBranch",
            "branchName",
            "rebased",
            "conflictsDetected",
            "details"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
