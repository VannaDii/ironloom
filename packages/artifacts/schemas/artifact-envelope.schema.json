{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ArtifactEnvelopeSchema",
  "definitions": {
    "ArtifactEnvelopeSchema": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "type": "string"
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "migration": {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "previousArtifactId": {
              "type": "string"
            },
            "migratedAt": {
              "type": "string"
            }
          },
          "required": ["schemaVersion"],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
