{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ArtifactEnvelopeSchema",
  "definitions": {
    "ArtifactEnvelopeSchema": {
      "$ref": "#/definitions/ArtifactEnvelope"
    },
    "ArtifactEnvelope": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "type": "string"
        },
        "version": {
          "type": "number",
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "migration": {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "number",
              "const": 1
            },
            "previousArtifactId": {
              "type": "string"
            },
            "migratedAt": {
              "type": "string"
            }
          },
          "required": ["schemaVersion"],
          "additionalProperties": false
        },
        "payload": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    }
  }
}
