{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AuditLogArtifact",
  "definitions": {
    "AuditLogArtifact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "const": "audit-log"
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "properties": {
            "auditId": {
              "type": "string"
            },
            "actorId": {
              "type": "string"
            },
            "action": {
              "type": "string"
            },
            "scope": {
              "type": "string"
            },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": ["auditId", "actorId", "action", "scope", "details"],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
