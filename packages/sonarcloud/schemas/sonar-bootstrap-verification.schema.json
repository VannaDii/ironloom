{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SonarBootstrapVerificationResult",
  "definitions": {
    "SonarBootstrapVerificationResult": {
      "type": "object",
      "properties": {
        "projectKey": {
          "type": "string"
        },
        "status": {
          "enum": ["failed", "passed"]
        },
        "qualityGateStatus": {
          "enum": ["ERROR", "NONE", "OK"]
        },
        "overallCoverageThreshold": {
          "type": "number"
        },
        "newCodeCoverageThreshold": {
          "type": "number"
        },
        "checks": {
          "type": "object",
          "properties": {
            "qualityGateComputed": {
              "type": "boolean"
            },
            "qualityGatePassing": {
              "type": "boolean"
            },
            "overallCoverageCondition": {
              "type": "boolean"
            },
            "newCodeCoverageCondition": {
              "type": "boolean"
            }
          },
          "required": [
            "qualityGateComputed",
            "qualityGatePassing",
            "overallCoverageCondition",
            "newCodeCoverageCondition"
          ],
          "additionalProperties": false
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "projectKey",
        "status",
        "qualityGateStatus",
        "overallCoverageThreshold",
        "newCodeCoverageThreshold",
        "checks",
        "issues",
        "evaluatedAt"
      ],
      "additionalProperties": false
    }
  }
}
