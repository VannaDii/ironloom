{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SonarQualityGateResult",
  "definitions": {
    "SonarQualityGateResult": {
      "type": "object",
      "properties": {
        "projectKey": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/QualityGateStatus"
        },
        "overallCoverage": {
          "type": "number"
        },
        "newCodeCoverage": {
          "type": "number"
        },
        "blockingIssues": {
          "type": "number"
        },
        "evaluatedAt": {
          "type": "string"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NormalizedSonarIssue"
          }
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "projectKey",
        "status",
        "overallCoverage",
        "newCodeCoverage",
        "blockingIssues",
        "evaluatedAt"
      ],
      "additionalProperties": false
    },
    "QualityGateStatus": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "NormalizedSonarIssue": {
      "type": "object",
      "properties": {
        "issueKey": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/definitions/NormalizedSonarIssueSeverity"
        },
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "effortMinutes": {
          "type": "number"
        },
        "blocking": {
          "type": "boolean"
        }
      },
      "required": [
        "issueKey",
        "severity",
        "path",
        "message",
        "effortMinutes",
        "blocking"
      ],
      "additionalProperties": false
    },
    "NormalizedSonarIssueSeverity": {
      "type": "string",
      "enum": ["info", "minor", "major", "critical", "blocker"]
    }
  }
}
