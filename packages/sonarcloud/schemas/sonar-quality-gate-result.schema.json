{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SonarQualityGateResult",
  "definitions": {
    "SonarQualityGateResult": {
      "type": "object",
      "properties": {
        "projectKey": {
          "type": "string"
        },
        "status": {
          "enum": ["passed", "failed"]
        },
        "overallCoverage": {
          "type": "number"
        },
        "newCodeCoverage": {
          "type": "number"
        },
        "blockingIssues": {
          "type": "number"
        },
        "evaluatedAt": {
          "type": "string"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "issueKey": {
                "type": "string"
              },
              "severity": {
                "enum": ["info", "minor", "major", "critical", "blocker"]
              },
              "path": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "effortMinutes": {
                "type": "number"
              },
              "blocking": {
                "type": "boolean"
              }
            },
            "required": [
              "issueKey",
              "severity",
              "path",
              "message",
              "effortMinutes",
              "blocking"
            ],
            "additionalProperties": false
          }
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "projectKey",
        "status",
        "overallCoverage",
        "newCodeCoverage",
        "blockingIssues",
        "evaluatedAt"
      ],
      "additionalProperties": false
    }
  }
}
