{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SupervisorContinuationDecision",
  "definitions": {
    "SupervisorContinuationDecision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "requestId": {
          "type": "string"
        },
        "repositoryKey": {
          "type": "string",
          "pattern": "^(?!.*(?:^|/)\\s)(?!.*\\s(?:/|$))[^/]+/[^/]+$"
        },
        "objective": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "nextAction": {
          "type": "object",
          "properties": {
            "kind": {
              "enum": [
                "create-research-brief",
                "create-spec-record",
                "request-spec-approval",
                "create-slice-plan",
                "create-task-record",
                "allocate-worktree",
                "run-gates",
                "create-remediation-plan",
                "create-pull-request-record",
                "submit-pull-request-update",
                "submit-pull-request-merge",
                "plan-rebase-dependents"
              ]
            },
            "phase": {
              "enum": [
                "research",
                "spec",
                "slicing",
                "implementation",
                "gates",
                "review",
                "remediation",
                "merge",
                "continuation"
              ]
            },
            "routedTo": {
              "type": "string"
            },
            "toolName": {
              "enum": [
                "create_research_brief",
                "create_spec_record",
                "approve_spec_record",
                "create_slice_plan",
                "create_task_record",
                "allocate_worktree",
                "run_gates",
                "create_remediation_plan",
                "create_pull_request_record",
                "submit_pull_request_update",
                "submit_pull_request_merge",
                "plan_rebase_dependents"
              ]
            },
            "summary": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "requiresHumanApproval": {
              "type": "boolean"
            },
            "artifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missingArtifactTypes": {
              "type": "array",
              "items": {
                "enum": [
                  "approval-record",
                  "audit-log",
                  "discord-thread-session",
                  "gate-run-report",
                  "merge-decision",
                  "pull-request-record",
                  "rebase-result",
                  "remediation-plan",
                  "research-brief",
                  "review-finding",
                  "slice-plan",
                  "spec-record",
                  "task-record",
                  "telemetry-event",
                  "worktree-allocation"
                ]
              }
            },
            "inputRequirements": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "kind",
            "phase",
            "routedTo",
            "toolName",
            "summary",
            "reason",
            "requiresHumanApproval",
            "artifactIds",
            "missingArtifactTypes",
            "inputRequirements"
          ],
          "additionalProperties": false
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "requestId",
        "repositoryKey",
        "objective",
        "actorId",
        "nextAction",
        "artifactIds",
        "blockers"
      ],
      "additionalProperties": false
    }
  }
}
