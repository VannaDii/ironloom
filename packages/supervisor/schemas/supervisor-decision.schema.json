{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SupervisorDecision",
  "definitions": {
    "SupervisorDecision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "action": {
          "type": "string"
        },
        "nextState": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "approved": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "enum": [
            "research",
            "spec",
            "slicing",
            "implementation",
            "gates",
            "review",
            "remediation",
            "merge",
            "continuation"
          ]
        },
        "routedTo": {
          "type": "string"
        },
        "routePlan": {
          "type": "object",
          "properties": {
            "currentPhase": {
              "enum": [
                "research",
                "spec",
                "slicing",
                "implementation",
                "gates",
                "review",
                "remediation",
                "merge",
                "continuation"
              ]
            },
            "nextPhase": {
              "enum": [
                "research",
                "spec",
                "slicing",
                "implementation",
                "gates",
                "review",
                "remediation",
                "merge",
                "continuation"
              ]
            },
            "routedTo": {
              "type": "string"
            },
            "nextAction": {
              "type": "string"
            },
            "status": {
              "enum": ["ready", "waiting", "blocked"]
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "artifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "auditReason": {
              "type": "string"
            }
          },
          "required": [
            "currentPhase",
            "nextPhase",
            "routedTo",
            "nextAction",
            "status",
            "blockers",
            "artifactIds",
            "auditReason"
          ],
          "additionalProperties": false
        },
        "lifecycleSignals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "phase": {
                "enum": [
                  "research",
                  "spec",
                  "slicing",
                  "implementation",
                  "gates",
                  "review",
                  "remediation",
                  "merge",
                  "continuation"
                ]
              },
              "ready": {
                "type": "boolean"
              },
              "artifactIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "blockers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "nextAction": {
                "type": "string"
              }
            },
            "required": [
              "phase",
              "ready",
              "artifactIds",
              "blockers",
              "nextAction"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "action",
        "nextState",
        "approved",
        "notes"
      ],
      "additionalProperties": false
    }
  }
}
