{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SupervisorDecision",
  "definitions": {
    "SupervisorDecision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "nextState": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "approved": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "$ref": "#/definitions/SupervisorPhase"
        },
        "routedTo": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "action",
        "nextState",
        "approved",
        "notes"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "SupervisorPhase": {
      "type": "string",
      "enum": [
        "research",
        "spec",
        "slicing",
        "implementation",
        "gates",
        "review",
        "remediation",
        "merge",
        "continuation"
      ]
    }
  }
}
