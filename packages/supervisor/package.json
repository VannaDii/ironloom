{
  "name": "@vannadii/devplat-supervisor",
  "version": "0.0.1",
  "description": "Lifecycle orchestration brain.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "node ../../scripts/run-tsc.mjs -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "node ../../scripts/run-tsc.mjs -p tsconfig.json --noEmit --pretty false",
    "test": "vitest run --config ../../vitest.package.config.mts"
  },
  "dependencies": {
    "io-ts": "2.2.22",
    "@vannadii/devplat-artifacts": "0.0.0",
    "@vannadii/devplat-branching": "0.0.1",
    "@vannadii/devplat-core": "0.0.0",
    "@vannadii/devplat-gates": "0.0.0",
    "@vannadii/devplat-observability": "0.0.0",
    "@vannadii/devplat-policy": "0.0.0",
    "@vannadii/devplat-prs": "0.1.0",
    "@vannadii/devplat-queue": "0.0.0",
    "@vannadii/devplat-remediation": "0.0.0",
    "@vannadii/devplat-review": "0.0.0",
    "@vannadii/devplat-slicing": "0.0.1",
    "@vannadii/devplat-specs": "0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/devplat.git",
    "directory": "packages/supervisor"
  },
  "bugs": {
    "url": "https://github.com/VannaDii/devplat/issues"
  },
  "homepage": "https://github.com/VannaDii/devplat#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
