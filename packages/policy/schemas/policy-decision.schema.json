{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/PolicyDecision",
  "definitions": {
    "PolicyDecision": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "action": {
          "type": "string"
        },
        "allowed": {
          "type": "boolean"
        },
        "requiresApproval": {
          "type": "boolean"
        },
        "auditRequired": {
          "type": "boolean"
        },
        "privilegeLevel": {
          "enum": [
            "automatic",
            "human-approval",
            "destructive",
            "external-publish"
          ]
        },
        "reason": {
          "type": "string"
        },
        "actionCategory": {
          "enum": [
            "merge",
            "command-execution",
            "worktree-release",
            "rebase",
            "publish",
            "autofix",
            "destructive-cleanup",
            "routine"
          ]
        },
        "riskLevel": {
          "enum": ["low", "medium", "high", "critical"]
        },
        "escalationRequired": {
          "type": "boolean"
        },
        "escalationTarget": {
          "enum": ["none", "operator", "maintainer", "release-manager"]
        },
        "nextAction": {
          "type": "string"
        },
        "auditReason": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "action",
        "allowed",
        "requiresApproval",
        "auditRequired",
        "privilegeLevel",
        "reason"
      ],
      "additionalProperties": false
    }
  }
}
