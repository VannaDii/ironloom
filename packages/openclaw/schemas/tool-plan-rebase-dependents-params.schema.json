{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/PlanRebaseDependentsToolInput",
  "definitions": {
    "PlanRebaseDependentsToolInput": {
      "type": "object",
      "properties": {
        "record": {
          "$ref": "#/definitions/PullRequestRecord"
        },
        "dependentBranches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["record", "dependentBranches"],
      "additionalProperties": false
    },
    "PullRequestRecord": {
      "type": "object",
      "properties": {
        "prNumber": {
          "type": "number"
        },
        "branchName": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reviewState": {
          "$ref": "#/definitions/PullRequestReviewState"
        },
        "mergeReady": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string"
        },
        "projection": {
          "$ref": "#/definitions/PullRequestProjection"
        },
        "sourceArtifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "prNumber",
        "branchName",
        "baseBranch",
        "title",
        "labels",
        "reviewState",
        "mergeReady",
        "updatedAt"
      ],
      "additionalProperties": false
    },
    "PullRequestReviewState": {
      "type": "string",
      "enum": ["draft", "review", "approved", "changes-requested"]
    },
    "PullRequestProjection": {
      "type": "object",
      "properties": {
        "body": {
          "type": "string"
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "riskSummary": {
          "type": "string"
        },
        "validationSummary": {
          "type": "string"
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "body",
        "checklist",
        "riskSummary",
        "validationSummary",
        "artifactIds"
      ],
      "additionalProperties": false
    }
  }
}
