{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/PlanRebaseDependentsToolInput",
  "definitions": {
    "PlanRebaseDependentsToolInput": {
      "type": "object",
      "properties": {
        "record": {
          "type": "object",
          "properties": {
            "prNumber": {
              "type": "number"
            },
            "branchName": {
              "type": "string"
            },
            "baseBranch": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reviewState": {
              "enum": ["draft", "review", "approved", "changes-requested"]
            },
            "mergeReady": {
              "type": "boolean"
            },
            "updatedAt": {
              "type": "string"
            },
            "projection": {
              "type": "object",
              "properties": {
                "body": {
                  "type": "string"
                },
                "checklist": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "riskSummary": {
                  "type": "string"
                },
                "validationSummary": {
                  "type": "string"
                },
                "artifactIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "body",
                "checklist",
                "riskSummary",
                "validationSummary",
                "artifactIds"
              ],
              "additionalProperties": false
            },
            "sourceArtifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "prNumber",
            "branchName",
            "baseBranch",
            "title",
            "labels",
            "reviewState",
            "mergeReady",
            "updatedAt"
          ],
          "additionalProperties": false
        },
        "dependentBranches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["record", "dependentBranches"],
      "additionalProperties": false
    }
  }
}
