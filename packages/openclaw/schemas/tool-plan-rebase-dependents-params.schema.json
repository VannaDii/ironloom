{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/PlanRebaseDependentsToolInput",
  "definitions": {
    "PlanRebaseDependentsToolInput": {
      "type": "object",
      "properties": {
        "record": {
          "type": "object",
          "properties": {
            "prNumber": {
              "type": "number"
            },
            "branchName": {
              "type": "string"
            },
            "baseBranch": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "reviewState": {
              "enum": ["draft", "review", "approved", "changes-requested"]
            },
            "mergeReady": {
              "type": "boolean"
            },
            "updatedAt": {
              "type": "string"
            },
            "projection": {
              "type": "object",
              "properties": {
                "body": {
                  "type": "string"
                },
                "checklist": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "riskSummary": {
                  "type": "string"
                },
                "validationSummary": {
                  "type": "string"
                },
                "artifactIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "body",
                "checklist",
                "riskSummary",
                "validationSummary",
                "artifactIds"
              ],
              "additionalProperties": false
            },
            "reviewProjection": {
              "type": "object",
              "properties": {
                "summaryId": {
                  "type": "string"
                },
                "findingIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "blockingFindingIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "missingCriteria": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "implementationMatchesSpec": {
                  "type": "boolean"
                }
              },
              "required": [
                "summaryId",
                "findingIds",
                "blockingFindingIds",
                "missingCriteria",
                "implementationMatchesSpec"
              ],
              "additionalProperties": false
            },
            "remediationProjection": {
              "type": "object",
              "properties": {
                "planId": {
                  "type": "string"
                },
                "successfulActions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "failedActions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "artifactIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "unresolvedFindingIds": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "complete": {
                  "type": "boolean"
                },
                "nextAction": {
                  "type": "string"
                }
              },
              "required": [
                "planId",
                "successfulActions",
                "failedActions",
                "artifactIds",
                "unresolvedFindingIds",
                "complete"
              ],
              "additionalProperties": false
            },
            "sourceArtifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "prNumber",
            "branchName",
            "baseBranch",
            "title",
            "labels",
            "reviewState",
            "mergeReady",
            "updatedAt"
          ],
          "additionalProperties": false
        },
        "dependentBranches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["record", "dependentBranches"],
      "additionalProperties": false
    }
  }
}
