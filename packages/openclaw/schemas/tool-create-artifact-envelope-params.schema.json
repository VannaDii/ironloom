{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateArtifactEnvelopeToolInput",
  "definitions": {
    "CreateArtifactEnvelopeToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "enum": [
            "approval-record",
            "audit-log",
            "discord-thread-session",
            "gate-run-report",
            "merge-decision",
            "pull-request-record",
            "rebase-result",
            "remediation-plan",
            "research-brief",
            "review-finding",
            "slice-plan",
            "spec-record",
            "task-record",
            "telemetry-event",
            "worktree-allocation"
          ]
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "migration": {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "previousArtifactId": {
              "type": "string"
            },
            "migratedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": ["schemaVersion"],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
