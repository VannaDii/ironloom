{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/SubmitGitHubActionToolInput",
  "definitions": {
    "SubmitGitHubActionToolInput": {
      "type": "object",
      "properties": {
        "request": {
          "type": "object",
          "properties": {
            "repoFullName": {
              "type": "string"
            },
            "action": {
              "enum": [
                "create-pr",
                "update-pr",
                "comment-pr",
                "merge-pr",
                "sync-branch"
              ]
            },
            "summary": {
              "type": "string"
            },
            "privileged": {
              "type": "boolean"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "targetNumber": {
              "type": "number"
            },
            "branchName": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "baseBranch": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "title": {
              "type": "string"
            },
            "body": {
              "type": "string"
            },
            "commentBody": {
              "type": "string"
            },
            "expectedHeadSha": {
              "type": "string"
            }
          },
          "required": [
            "repoFullName",
            "action",
            "summary",
            "privileged",
            "updatedAt"
          ],
          "additionalProperties": false
        },
        "actorId": {
          "type": "string"
        }
      },
      "required": ["request", "actorId"],
      "additionalProperties": false
    }
  }
}
