{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/VerifySonarBootstrapToolInput",
  "definitions": {
    "VerifySonarBootstrapToolInput": {
      "type": "object",
      "properties": {
        "projectKey": {
          "type": "string"
        },
        "qualityGateStatus": {
          "enum": ["ERROR", "NONE", "OK"]
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metricKey": {
                "type": "string"
              },
              "comparator": {
                "type": "string"
              },
              "errorThreshold": {
                "type": "string"
              },
              "actualValue": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "metricKey",
              "comparator",
              "errorThreshold",
              "actualValue"
            ],
            "additionalProperties": false
          }
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "projectKey",
        "qualityGateStatus",
        "conditions",
        "evaluatedAt"
      ],
      "additionalProperties": false
    }
  }
}
