{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/HandleDiscordApprovalToolInput",
  "definitions": {
    "HandleDiscordApprovalToolInput": {
      "$ref": "#/definitions/DiscordApprovalRequest"
    },
    "DiscordApprovalRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "action": {
          "$ref": "#/definitions/DiscordApprovalAction"
        },
        "artifactId": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "actorId",
        "channelId",
        "threadId",
        "action",
        "artifactId",
        "privileged"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "DiscordApprovalAction": {
      "type": "string",
      "enum": ["approve", "retry", "merge", "escalate"]
    }
  }
}
