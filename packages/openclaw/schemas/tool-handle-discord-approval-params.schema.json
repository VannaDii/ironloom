{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/HandleDiscordApprovalToolInput",
  "definitions": {
    "HandleDiscordApprovalToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "actorId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "action": {
          "enum": ["approve", "retry", "merge", "escalate"]
        },
        "artifactId": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "actorId",
        "channelId",
        "threadId",
        "action",
        "artifactId",
        "privileged"
      ],
      "additionalProperties": false
    }
  }
}
