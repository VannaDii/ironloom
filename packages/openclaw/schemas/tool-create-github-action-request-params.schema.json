{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateGitHubActionRequestToolInput",
  "definitions": {
    "CreateGitHubActionRequestToolInput": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "action": {
          "enum": [
            "create-pr",
            "update-pr",
            "comment-pr",
            "merge-pr",
            "sync-branch"
          ]
        },
        "summary": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string"
        },
        "targetNumber": {
          "type": "number"
        },
        "branchName": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "commentBody": {
          "type": "string"
        },
        "expectedHeadSha": {
          "type": "string"
        }
      },
      "required": [
        "repoFullName",
        "action",
        "summary",
        "privileged",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
