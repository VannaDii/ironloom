{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateGitHubActionRequestToolInput",
  "definitions": {
    "CreateGitHubActionRequestToolInput": {
      "$ref": "#/definitions/GitHubActionRequest"
    },
    "GitHubActionRequest": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "action": {
          "$ref": "#/definitions/GitHubAction"
        },
        "summary": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        },
        "targetNumber": {
          "type": "number"
        },
        "branchName": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "commentBody": {
          "type": "string"
        },
        "expectedHeadSha": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "repoFullName",
        "action",
        "summary",
        "privileged",
        "updatedAt"
      ],
      "additionalProperties": false
    },
    "GitHubAction": {
      "type": "string",
      "enum": [
        "create-pr",
        "update-pr",
        "comment-pr",
        "merge-pr",
        "sync-branch"
      ]
    }
  }
}
