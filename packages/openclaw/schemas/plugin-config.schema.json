{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/OpenClawPluginConfig",
  "definitions": {
    "OpenClawPluginConfig": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "apiBaseUrl": {
          "type": "string"
        },
        "apiVersion": {
          "type": "string",
          "const": "v10"
        },
        "applicationId": {
          "type": "string"
        },
        "publicKey": {
          "type": "string"
        },
        "botToken": {
          "type": "string"
        },
        "installScopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["bot", "applications.commands"]
          }
        },
        "requiredPermissions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ViewChannel",
              "SendMessages",
              "CreatePublicThreads",
              "CreatePrivateThreads",
              "SendMessagesInThreads",
              "ManageThreads",
              "ReadMessageHistory"
            ]
          }
        },
        "defaultGuildId": {
          "type": "string"
        },
        "specChannelId": {
          "type": "string"
        },
        "implementationChannelId": {
          "type": "string"
        },
        "pullRequestChannelId": {
          "type": "string"
        },
        "auditChannelId": {
          "type": "string"
        },
        "projectManagementChannelId": {
          "type": "string"
        },
        "threadBindingMode": {
          "type": "string",
          "const": "inherit-parent"
        },
        "actionGates": {
          "type": "object",
          "properties": {
            "approveThis": {
              "type": "boolean"
            },
            "mergeNow": {
              "type": "boolean"
            },
            "retryGates": {
              "type": "boolean"
            },
            "rebaseAllDependents": {
              "type": "boolean"
            }
          },
          "required": [
            "approveThis",
            "mergeNow",
            "retryGates",
            "rebaseAllDependents"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "apiBaseUrl",
        "apiVersion",
        "applicationId",
        "publicKey",
        "botToken",
        "installScopes",
        "requiredPermissions",
        "defaultGuildId",
        "specChannelId",
        "implementationChannelId",
        "pullRequestChannelId",
        "auditChannelId",
        "projectManagementChannelId",
        "threadBindingMode",
        "actionGates"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    }
  }
}
