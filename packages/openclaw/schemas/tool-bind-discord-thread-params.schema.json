{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/BindDiscordThreadToolInput",
  "definitions": {
    "BindDiscordThreadToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "guildId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "kind": {
          "enum": ["spec", "implementation", "pull-request", "audit"]
        },
        "threadBindingMode": {
          "const": "inherit-parent"
        },
        "threadId": {
          "type": "string"
        },
        "parentChannelId": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "guildId",
        "channelId",
        "kind",
        "threadBindingMode",
        "threadId",
        "parentChannelId",
        "actorId"
      ],
      "additionalProperties": false
    }
  }
}
