{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/UpdateSpecRecordToolInput",
  "definitions": {
    "UpdateSpecRecordToolInput": {
      "type": "object",
      "properties": {
        "specId": {
          "type": "string"
        },
        "researchId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvalState": {
          "enum": ["draft", "review", "approved"]
        },
        "version": {
          "type": "number"
        },
        "updatedAt": {
          "type": "string"
        },
        "revisionHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "version": {
                "type": "number"
              },
              "summary": {
                "type": "string"
              },
              "updatedAt": {
                "type": "string"
              },
              "artifactId": {
                "type": "string"
              }
            },
            "required": ["version", "summary", "updatedAt"],
            "additionalProperties": false
          }
        },
        "renderedPullRequestBody": {
          "type": "string"
        },
        "sourceArtifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "specId",
        "researchId",
        "title",
        "objective",
        "acceptanceCriteria",
        "approvalState",
        "version",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
