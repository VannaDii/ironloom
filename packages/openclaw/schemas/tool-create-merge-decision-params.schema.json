{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateMergeDecisionToolInput",
  "definitions": {
    "CreateMergeDecisionToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "const": "merge-decision"
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "properties": {
            "decisionId": {
              "type": "string"
            },
            "prNumber": {
              "type": "number"
            },
            "actorId": {
              "type": "string"
            },
            "mergeStrategy": {
              "enum": ["merge", "squash", "rebase"]
            },
            "approved": {
              "type": "boolean"
            },
            "rationale": {
              "type": "string"
            },
            "blockingFindings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "decisionId",
            "prNumber",
            "actorId",
            "mergeStrategy",
            "approved",
            "rationale",
            "blockingFindings"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
