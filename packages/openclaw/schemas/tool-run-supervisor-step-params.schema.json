{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/RunSupervisorStepToolInput",
  "definitions": {
    "RunSupervisorStepToolInput": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        },
        "lifecycleSignals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "phase": {
                "enum": [
                  "research",
                  "spec",
                  "slicing",
                  "implementation",
                  "gates",
                  "review",
                  "remediation",
                  "merge",
                  "continuation"
                ]
              },
              "ready": {
                "type": "boolean"
              },
              "artifactIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "blockers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "nextAction": {
                "type": "string"
              }
            },
            "required": [
              "phase",
              "ready",
              "artifactIds",
              "blockers",
              "nextAction"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": ["action", "actorId", "privileged"],
      "additionalProperties": false
    }
  }
}
