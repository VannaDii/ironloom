{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/HandleDiscordControlToolInput",
  "definitions": {
    "HandleDiscordControlToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "action": {
          "enum": [
            "run-this",
            "claim-this",
            "approve-this",
            "block-this",
            "complete-this",
            "pause-this",
            "resume-this",
            "rebase-all-dependents",
            "retry-gates",
            "merge-now",
            "show-status",
            "show-last-artifact",
            "explain-failure",
            "sync-worktree",
            "release-worktree",
            "update-spec"
          ]
        },
        "privileged": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "actorId",
        "threadId",
        "channelId",
        "action",
        "privileged"
      ],
      "additionalProperties": false
    }
  }
}
