{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AllocateWorktreeToolInput",
  "definitions": {
    "AllocateWorktreeToolInput": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "branchName": {
          "type": "string"
        },
        "baseBranch": {
          "type": "string",
          "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
        },
        "applyToDisk": {
          "type": "boolean"
        }
      },
      "required": ["taskId", "branchName"],
      "additionalProperties": false
    }
  }
}
