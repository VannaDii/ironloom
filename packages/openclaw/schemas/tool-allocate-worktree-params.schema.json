{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AllocateWorktreeToolInput",
  "definitions": {
    "AllocateWorktreeToolInput": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            },
            "branchName": {
              "type": "string"
            },
            "baseBranch": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "applyToDisk": {
              "const": true
            }
          },
          "required": ["taskId", "branchName", "baseBranch", "applyToDisk"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string"
            },
            "branchName": {
              "type": "string"
            },
            "baseBranch": {
              "type": "string",
              "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
            },
            "applyToDisk": {
              "const": false
            }
          },
          "required": ["taskId", "branchName"],
          "additionalProperties": false
        }
      ]
    }
  }
}
