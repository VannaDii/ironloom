{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ReleaseWorktreeToolInput",
  "definitions": {
    "ReleaseWorktreeToolInput": {
      "type": "object",
      "properties": {
        "allocation": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "status": {
              "enum": [
                "draft",
                "queued",
                "claimed",
                "running",
                "review",
                "blocked",
                "approved",
                "merge-ready",
                "merged",
                "failed",
                "rebasing",
                "complete"
              ]
            },
            "trace": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "updatedAt": {
              "type": "string"
            },
            "taskId": {
              "type": "string"
            },
            "branchName": {
              "type": "string"
            },
            "worktreePath": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "summary",
            "status",
            "trace",
            "updatedAt",
            "taskId",
            "branchName",
            "worktreePath"
          ],
          "additionalProperties": false
        },
        "releaseMode": {
          "enum": ["archive", "delete"]
        }
      },
      "required": ["allocation"],
      "additionalProperties": false
    }
  }
}
