{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateSlicePlanToolInput",
  "definitions": {
    "CreateSlicePlanToolInput": {
      "type": "object",
      "properties": {
        "sliceId": {
          "type": "string"
        },
        "specId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "doneConditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size": {
          "enum": ["small", "medium", "large"]
        },
        "updatedAt": {
          "type": "string"
        },
        "dependencyGraph": {
          "type": "object",
          "properties": {
            "sliceId": {
              "type": "string"
            },
            "graphId": {
              "type": "string"
            },
            "generatedAt": {
              "type": "string"
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fromSliceId": {
                    "type": "string"
                  },
                  "toSliceId": {
                    "type": "string"
                  }
                },
                "required": ["fromSliceId", "toSliceId"],
                "additionalProperties": false
              }
            },
            "blockedBy": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "dependencyCount": {
              "type": "number"
            }
          },
          "required": [
            "sliceId",
            "graphId",
            "generatedAt",
            "edges",
            "blockedBy",
            "dependencyCount"
          ],
          "additionalProperties": false
        },
        "workPacket": {
          "type": "object",
          "properties": {
            "packetId": {
              "type": "string"
            },
            "branchName": {
              "type": "string"
            },
            "taskIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "estimatedTaskCount": {
              "type": "number"
            },
            "estimatedPullRequestCount": {
              "type": "number"
            },
            "pullRequestTitle": {
              "type": "string"
            },
            "reviewFocus": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "packetId",
            "branchName",
            "taskIds",
            "estimatedTaskCount",
            "estimatedPullRequestCount",
            "pullRequestTitle",
            "reviewFocus"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "sliceId",
        "specId",
        "title",
        "dependsOn",
        "acceptanceCriteria",
        "doneConditions",
        "size",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
