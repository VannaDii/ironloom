{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CreateApprovalRecordToolInput",
  "definitions": {
    "CreateApprovalRecordToolInput": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "artifactType": {
          "const": "approval-record"
        },
        "version": {
          "const": 1
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "properties": {
            "approvalId": {
              "type": "string"
            },
            "subjectType": {
              "enum": ["spec", "slice", "pull-request", "merge"]
            },
            "subjectId": {
              "type": "string"
            },
            "actorId": {
              "type": "string"
            },
            "decision": {
              "enum": ["approved", "rejected", "needs-changes"]
            },
            "rationale": {
              "type": "string"
            }
          },
          "required": [
            "approvalId",
            "subjectType",
            "subjectId",
            "actorId",
            "decision",
            "rationale"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "artifactType",
        "version",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    }
  }
}
