{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/UpdateTaskToolInput",
  "definitions": {
    "UpdateTaskToolInput": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "sliceId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        }
      },
      "required": ["taskId", "sliceId", "threadId", "status"],
      "additionalProperties": false
    }
  }
}
