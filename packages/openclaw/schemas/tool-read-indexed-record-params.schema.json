{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ReadIndexedRecordToolInput",
  "definitions": {
    "ReadIndexedRecordToolInput": {
      "type": "object",
      "properties": {
        "indexName": {
          "enum": [
            "active-thread",
            "task",
            "pull-request",
            "branch",
            "artifact"
          ]
        },
        "key": {
          "type": "string"
        }
      },
      "required": ["indexName", "key"],
      "additionalProperties": false
    }
  }
}
