{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/StoreRecordToolInput",
  "definitions": {
    "StoreRecordToolInput": {
      "type": "object",
      "properties": {
        "record": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "key": {
              "type": "string"
            },
            "scope": {
              "enum": [
                "artifacts",
                "audit",
                "gates",
                "memory",
                "pull-requests",
                "remediation",
                "reviews",
                "slices",
                "specs",
                "state",
                "tasks",
                "telemetry",
                "worktrees"
              ]
            },
            "summary": {
              "type": "string"
            },
            "status": {
              "enum": [
                "draft",
                "queued",
                "claimed",
                "running",
                "review",
                "blocked",
                "approved",
                "merge-ready",
                "merged",
                "failed",
                "rebasing",
                "complete"
              ]
            },
            "trace": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "payload": {
              "type": "object",
              "additionalProperties": true
            },
            "layoutVersion": {
              "const": 1
            },
            "indexes": {
              "type": "array",
              "items": {
                "enum": [
                  "active-thread",
                  "task",
                  "pull-request",
                  "branch",
                  "artifact"
                ]
              }
            }
          },
          "required": [
            "id",
            "key",
            "scope",
            "summary",
            "status",
            "trace",
            "updatedAt",
            "payload"
          ],
          "additionalProperties": false
        },
        "actorId": {
          "type": "string"
        },
        "privileged": {
          "type": "boolean"
        }
      },
      "required": ["record", "actorId", "privileged"],
      "additionalProperties": false
    }
  }
}
