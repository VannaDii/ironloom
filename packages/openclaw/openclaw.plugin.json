{
  "id": "@vannadii/devplat-openclaw",
  "entry": "./dist/index.js",
  "configSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$ref": "#/definitions/OpenClawPluginConfig",
    "definitions": {
      "OpenClawPluginConfig": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "status": {
            "enum": [
              "draft",
              "queued",
              "claimed",
              "running",
              "review",
              "blocked",
              "approved",
              "merge-ready",
              "merged",
              "failed",
              "rebasing",
              "complete"
            ]
          },
          "trace": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "apiBaseUrl": {
            "type": "string"
          },
          "apiVersion": {
            "const": "v10"
          },
          "applicationId": {
            "type": "string"
          },
          "categoryName": {
            "type": "string"
          },
          "publicKey": {
            "type": "string"
          },
          "botToken": {
            "type": "string"
          },
          "installScopes": {
            "type": "array",
            "items": {
              "enum": ["bot", "applications.commands"]
            }
          },
          "requiredPermissions": {
            "type": "array",
            "items": {
              "enum": [
                "ViewChannel",
                "SendMessages",
                "CreatePublicThreads",
                "CreatePrivateThreads",
                "SendMessagesInThreads",
                "ManageThreads",
                "ReadMessageHistory"
              ]
            }
          },
          "defaultGuildId": {
            "type": "string"
          },
          "specChannelId": {
            "type": "string"
          },
          "implementationChannelId": {
            "type": "string"
          },
          "pullRequestChannelId": {
            "type": "string"
          },
          "auditChannelId": {
            "type": "string"
          },
          "projectManagementChannelId": {
            "type": "string"
          },
          "threadBindingMode": {
            "const": "inherit-parent"
          },
          "actionGates": {
            "type": "object",
            "properties": {
              "approveThis": {
                "type": "boolean"
              },
              "mergeNow": {
                "type": "boolean"
              },
              "retryGates": {
                "type": "boolean"
              },
              "rebaseAllDependents": {
                "type": "boolean"
              }
            },
            "required": [
              "approveThis",
              "mergeNow",
              "retryGates",
              "rebaseAllDependents"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "summary",
          "status",
          "trace",
          "updatedAt",
          "apiBaseUrl",
          "apiVersion",
          "applicationId",
          "categoryName",
          "publicKey",
          "botToken",
          "installScopes",
          "requiredPermissions",
          "defaultGuildId",
          "specChannelId",
          "implementationChannelId",
          "pullRequestChannelId",
          "auditChannelId",
          "projectManagementChannelId",
          "threadBindingMode",
          "actionGates"
        ],
        "additionalProperties": false
      }
    }
  },
  "contracts": {
    "tools": [
      "create_research_brief",
      "create_spec_record",
      "approve_spec_record",
      "update_spec_record",
      "create_slice_plan",
      "evaluate_slice_plan_readiness",
      "resolve_runtime_config",
      "create_openclaw_plugin_config",
      "create_artifact_envelope",
      "create_approval_record",
      "create_audit_log",
      "create_merge_decision",
      "create_rebase_result",
      "execute_command",
      "run_gates",
      "allocate_worktree",
      "sync_worktree",
      "release_worktree",
      "bind_discord_thread",
      "open_discord_thread",
      "handle_discord_approval",
      "handle_discord_control",
      "verify_sonar_bootstrap",
      "evaluate_sonar_quality_gate",
      "create_review_finding",
      "create_remediation_plan",
      "remember_memory_entry",
      "evaluate_policy_action",
      "record_telemetry_event",
      "create_task_record",
      "claim_task",
      "update_task",
      "read_stored_record",
      "list_stored_records",
      "read_stored_index",
      "read_indexed_record",
      "list_stored_index",
      "store_record",
      "create_pull_request_record",
      "submit_pull_request_update",
      "submit_pull_request_merge",
      "plan_rebase_dependents",
      "execute_rebase_dependents",
      "create_github_action_request",
      "submit_github_action",
      "validate_artifact",
      "run_supervisor_step",
      "continue_lifecycle"
    ]
  },
  "name": "DevPlat OpenClaw Adapter",
  "version": "0.2.0",
  "description": "DevPlat capability bridge for OpenClaw with Discord-first operational flows."
}
