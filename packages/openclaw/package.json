{
  "name": "@vannadii/devplat-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw adapter layer for DevPlat.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "node ../../scripts/run-tsc.mjs -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "node ../../scripts/run-tsc.mjs -p tsconfig.json --noEmit --pretty false",
    "test": "vitest run --config ../../vitest.package.config.mts"
  },
  "dependencies": {
    "@vannadii/devplat-artifacts": "0.0.0",
    "@vannadii/devplat-branching": "0.0.1",
    "@vannadii/devplat-config": "0.1.0",
    "@vannadii/devplat-core": "0.0.0",
    "@vannadii/devplat-discord": "0.1.0",
    "@vannadii/devplat-execution": "0.0.0",
    "@vannadii/devplat-gates": "0.0.0",
    "@vannadii/devplat-github": "0.0.0",
    "@vannadii/devplat-memory": "0.0.0",
    "@vannadii/devplat-observability": "0.0.0",
    "@vannadii/devplat-policy": "0.0.0",
    "@vannadii/devplat-prs": "0.1.0",
    "@vannadii/devplat-queue": "0.0.0",
    "@vannadii/devplat-remediation": "0.0.0",
    "@vannadii/devplat-research": "0.0.0",
    "@vannadii/devplat-review": "0.0.0",
    "@vannadii/devplat-slicing": "0.0.1",
    "@vannadii/devplat-sonarcloud": "0.0.0",
    "@vannadii/devplat-specs": "0.1.0",
    "@vannadii/devplat-storage": "0.0.0",
    "@vannadii/devplat-supervisor": "0.0.1",
    "@vannadii/devplat-worktrees": "0.1.0",
    "io-ts": "2.2.22",
    "openclaw": "2026.4.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/devplat.git",
    "directory": "packages/openclaw"
  },
  "bugs": {
    "url": "https://github.com/VannaDii/devplat/issues"
  },
  "homepage": "https://github.com/VannaDii/devplat#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
