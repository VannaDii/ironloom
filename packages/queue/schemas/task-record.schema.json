{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/TaskRecord",
  "definitions": {
    "TaskRecord": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "sliceId": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        },
        "assigneeId": {
          "type": "string"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TaskTransitionEvent"
          }
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "taskId",
        "sliceId",
        "threadId"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "TaskTransitionEvent": {
      "type": "object",
      "properties": {
        "fromStatus": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "toStatus": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "action": {
          "$ref": "#/definitions/TaskTransitionAction"
        },
        "actorId": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "occurredAt": {
          "type": "string"
        }
      },
      "required": ["toStatus", "action", "reason", "occurredAt"],
      "additionalProperties": false
    },
    "TaskTransitionAction": {
      "type": "string",
      "enum": ["create", "claim", "status-update", "complete", "block"]
    }
  }
}
