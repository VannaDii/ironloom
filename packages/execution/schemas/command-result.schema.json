{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/CommandResult",
  "definitions": {
    "CommandResult": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exitCode": {
          "type": "number"
        },
        "timedOut": {
          "type": "boolean"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "durationMs": {
          "type": "number"
        },
        "attempts": {
          "type": "number"
        },
        "truncated": {
          "type": "boolean"
        },
        "policy": {
          "type": "object",
          "properties": {
            "retry": {
              "type": "object",
              "properties": {
                "attempts": {
                  "type": "number"
                },
                "retryableExitCodes": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  }
                }
              },
              "required": ["attempts", "retryableExitCodes"],
              "additionalProperties": false
            },
            "truncation": {
              "type": "object",
              "properties": {
                "maxOutputBytes": {
                  "type": "number"
                },
                "mode": {
                  "const": "bytes"
                }
              },
              "required": ["maxOutputBytes", "mode"],
              "additionalProperties": false
            },
            "timeoutMs": {
              "type": "number"
            }
          },
          "required": ["retry"],
          "additionalProperties": false
        }
      },
      "required": [
        "command",
        "args",
        "exitCode",
        "timedOut",
        "stdout",
        "stderr",
        "durationMs"
      ],
      "additionalProperties": false
    }
  }
}
