{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GateRunReport",
  "definitions": {
    "GateRunReport": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GateCheckResult"
          }
        },
        "classification": {
          "$ref": "#/definitions/GateFailureClassification"
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "passed",
        "results"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "GateCheckResult": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "success": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        },
        "failureKind": {
          "type": "string",
          "enum": ["command-failed", "timeout", "passed"]
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": ["name", "success", "detail"],
      "additionalProperties": false
    },
    "GateFailureClassification": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["passed", "retryable", "requires-remediation"]
        },
        "failedGateNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": ["kind", "failedGateNames", "nextAction"],
      "additionalProperties": false
    }
  }
}
