{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GateRunReport",
  "definitions": {
    "GateRunReport": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "passed": {
          "type": "boolean"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "success": {
                "type": "boolean"
              },
              "detail": {
                "type": "string"
              },
              "failureKind": {
                "enum": ["command-failed", "timeout", "passed"]
              },
              "nextAction": {
                "type": "string"
              }
            },
            "required": ["name", "success", "detail"],
            "additionalProperties": false
          }
        },
        "classification": {
          "type": "object",
          "properties": {
            "kind": {
              "enum": ["passed", "retryable", "requires-remediation"]
            },
            "failedGateNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nextAction": {
              "type": "string"
            }
          },
          "required": ["kind", "failedGateNames", "nextAction"],
          "additionalProperties": false
        },
        "remediationHook": {
          "type": "object",
          "properties": {
            "hookId": {
              "type": "string"
            },
            "gateRunReportId": {
              "type": "string"
            },
            "failedGateNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "retryableGateNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "remediationFindingIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "autofixEligible": {
              "type": "boolean"
            },
            "approvalRequired": {
              "type": "boolean"
            },
            "nextAction": {
              "type": "string"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "hookId",
            "gateRunReportId",
            "failedGateNames",
            "retryableGateNames",
            "remediationFindingIds",
            "actions",
            "autofixEligible",
            "approvalRequired",
            "nextAction",
            "createdAt"
          ],
          "additionalProperties": false
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "passed",
        "results"
      ],
      "additionalProperties": false
    }
  }
}
