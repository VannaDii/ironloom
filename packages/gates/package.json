{
  "name": "@vannadii/devplat-gates",
  "version": "0.0.0",
  "description": "Quality gate orchestration.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "node ../../scripts/run-tsc.mjs -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "node ../../scripts/run-tsc.mjs -p tsconfig.json --noEmit --pretty false",
    "test": "vitest run --config ../../vitest.package.config.mts"
  },
  "dependencies": {
    "io-ts": "2.2.22",
    "@vannadii/devplat-artifacts": "file:../artifacts",
    "@vannadii/devplat-core": "file:../core",
    "@vannadii/devplat-execution": "file:../execution"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/devplat.git",
    "directory": "packages/gates"
  },
  "bugs": {
    "url": "https://github.com/VannaDii/devplat/issues"
  },
  "homepage": "https://github.com/VannaDii/devplat#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
