{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GitHubRepositoryState",
  "definitions": {
    "GitHubRepositoryState": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "defaultBranch": {
          "type": "string",
          "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
        },
        "protectedBranches": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
          }
        },
        "openPullRequestNumbers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "linkedIssueNumbers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "repoFullName",
        "defaultBranch",
        "protectedBranches",
        "openPullRequestNumbers",
        "linkedIssueNumbers",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
