{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GitHubRepositoryState",
  "definitions": {
    "GitHubRepositoryState": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "defaultBranch": {
          "type": "string"
        },
        "protectedBranches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "openPullRequestNumbers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "linkedIssueNumbers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "repoFullName",
        "defaultBranch",
        "protectedBranches",
        "openPullRequestNumbers",
        "linkedIssueNumbers",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
