{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GitHubIssueSpecLink",
  "definitions": {
    "GitHubIssueSpecLink": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "issueNumber": {
          "type": "number"
        },
        "specId": {
          "type": "string"
        },
        "pullRequestNumber": {
          "type": "number"
        },
        "status": {
          "enum": ["planned", "in-progress", "blocked", "complete"]
        },
        "updatedAt": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        }
      },
      "required": [
        "repoFullName",
        "issueNumber",
        "specId",
        "pullRequestNumber",
        "status",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
