{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/GitHubPullRequestState",
  "definitions": {
    "GitHubPullRequestState": {
      "type": "object",
      "properties": {
        "repoFullName": {
          "type": "string"
        },
        "number": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "state": {
          "enum": ["open", "closed", "merged"]
        },
        "headBranch": {
          "type": "string",
          "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
        },
        "baseBranch": {
          "type": "string",
          "pattern": "^(?!-)(?!/)(?!.*(?:\\.\\.|//|@\\{|\\\\|~|\\^|:|\\?|\\*|\\[|(?:^|/)[^/]*\\.lock(?:/|$)))(?!.*[\\x00-\\x20\\x7f])(?!.*/$)(?!.*\\.$)(?!@$).+$"
        },
        "headSha": {
          "type": "string"
        },
        "issueNumbers": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checkState": {
          "enum": ["pending", "passing", "failing", "unknown"]
        },
        "reviewDecision": {
          "enum": [
            "approved",
            "changes-requested",
            "review-required",
            "unknown"
          ]
        },
        "mergeable": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "specId": {
          "type": "string"
        }
      },
      "required": [
        "repoFullName",
        "number",
        "title",
        "state",
        "headBranch",
        "baseBranch",
        "headSha",
        "issueNumbers",
        "labels",
        "checkState",
        "reviewDecision",
        "mergeable",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
