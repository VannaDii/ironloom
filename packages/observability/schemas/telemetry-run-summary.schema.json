{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/TelemetryRunSummary",
  "definitions": {
    "TelemetryRunSummary": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "eventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scopes": {
          "type": "array",
          "items": {
            "enum": ["discord", "github", "supervisor", "storage"]
          }
        },
        "actionCount": {
          "type": "number"
        },
        "failedCount": {
          "type": "number"
        },
        "auditRecordIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runMetrics": {
          "type": "object",
          "properties": {
            "runId": {
              "type": "string"
            },
            "durationMs": {
              "type": "number"
            },
            "scopeCounts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "scope": {
                    "enum": ["discord", "github", "supervisor", "storage"]
                  },
                  "count": {
                    "type": "number"
                  }
                },
                "required": ["scope", "count"],
                "additionalProperties": false
              }
            },
            "statusCounts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "status": {
                    "enum": [
                      "draft",
                      "queued",
                      "claimed",
                      "running",
                      "review",
                      "blocked",
                      "approved",
                      "merge-ready",
                      "merged",
                      "failed",
                      "rebasing",
                      "complete"
                    ]
                  },
                  "count": {
                    "type": "number"
                  }
                },
                "required": ["status", "count"],
                "additionalProperties": false
              }
            },
            "privilegedActionCount": {
              "type": "number"
            },
            "blockedCount": {
              "type": "number"
            },
            "failedCount": {
              "type": "number"
            },
            "auditRecordIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "artifactIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "runId",
            "durationMs",
            "scopeCounts",
            "statusCounts",
            "privilegedActionCount",
            "blockedCount",
            "failedCount",
            "auditRecordIds",
            "artifactIds"
          ],
          "additionalProperties": false
        },
        "startedAt": {
          "type": "string"
        },
        "completedAt": {
          "type": "string"
        }
      },
      "required": [
        "runId",
        "eventIds",
        "scopes",
        "actionCount",
        "failedCount",
        "auditRecordIds",
        "artifactIds",
        "runMetrics",
        "startedAt",
        "completedAt"
      ],
      "additionalProperties": false
    }
  }
}
