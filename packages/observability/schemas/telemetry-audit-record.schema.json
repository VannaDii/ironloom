{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/TelemetryAuditRecord",
  "definitions": {
    "TelemetryAuditRecord": {
      "type": "object",
      "properties": {
        "auditId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "eventId": {
          "type": "string"
        },
        "actorId": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "scope": {
          "enum": ["discord", "github", "supervisor", "storage"]
        },
        "outcome": {
          "enum": ["approved", "blocked", "failed", "completed", "pending"]
        },
        "reason": {
          "type": "string"
        },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recordedAt": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        },
        "policyDecisionId": {
          "type": "string"
        }
      },
      "required": [
        "auditId",
        "runId",
        "eventId",
        "actorId",
        "action",
        "scope",
        "outcome",
        "reason",
        "artifactIds",
        "recordedAt",
        "details"
      ],
      "additionalProperties": false
    }
  }
}
