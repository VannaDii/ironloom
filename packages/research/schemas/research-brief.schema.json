{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ResearchBrief",
  "definitions": {
    "ResearchBrief": {
      "type": "object",
      "properties": {
        "researchId": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendation": {
          "type": "string"
        },
        "sourceUrls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceAttributions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "claim": {
                "type": "string"
              },
              "confidence": {
                "enum": ["low", "medium", "high"]
              }
            },
            "required": ["url", "title", "claim", "confidence"],
            "additionalProperties": false
          }
        },
        "capabilityComparisons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "option": {
                "type": "string"
              },
              "strengths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tradeoffs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["option", "strengths", "tradeoffs"],
            "additionalProperties": false
          }
        },
        "feasibility": {
          "type": "object",
          "properties": {
            "feasible": {
              "type": "boolean"
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nextQuestions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["feasible", "blockers", "nextQuestions"],
          "additionalProperties": false
        }
      },
      "required": [
        "researchId",
        "topic",
        "question",
        "constraints",
        "findings",
        "recommendation",
        "sourceUrls",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
