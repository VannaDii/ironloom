{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/RemediationPlan",
  "definitions": {
    "RemediationPlan": {
      "type": "object",
      "properties": {
        "planId": {
          "type": "string"
        },
        "findingIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "autofix": {
          "type": "boolean"
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string"
              },
              "success": {
                "type": "boolean"
              },
              "detail": {
                "type": "string"
              },
              "completedAt": {
                "type": "string",
                "format": "date-time"
              },
              "artifactId": {
                "type": "string"
              }
            },
            "required": ["action", "success", "detail", "completedAt"],
            "additionalProperties": false
          }
        },
        "unresolvedFindingIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextAction": {
          "type": "string"
        }
      },
      "required": [
        "planId",
        "findingIds",
        "actions",
        "autofix",
        "approvalRequired",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
