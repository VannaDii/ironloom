{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DiscordWorkItemBinding",
  "definitions": {
    "DiscordWorkItemBinding": {
      "type": "object",
      "properties": {
        "threadKind": {
          "enum": ["spec", "implementation", "pull-request"]
        },
        "threadId": {
          "type": "string"
        },
        "artifactId": {
          "type": "string"
        },
        "specId": {
          "type": "string"
        },
        "sliceId": {
          "type": "string"
        },
        "pullRequestNumber": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["threadKind", "threadId", "artifactId"],
      "additionalProperties": false
    }
  }
}
