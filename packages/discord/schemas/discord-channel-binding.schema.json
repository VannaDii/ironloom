{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DiscordChannelBinding",
  "definitions": {
    "DiscordChannelBinding": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "guildId": {
          "type": "string"
        },
        "channelId": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/DiscordBindingKind"
        },
        "threadBindingMode": {
          "type": "string",
          "const": "inherit-parent"
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "guildId",
        "channelId",
        "kind",
        "threadBindingMode"
      ],
      "additionalProperties": false
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "DiscordBindingKind": {
      "type": "string",
      "enum": ["spec", "implementation", "pull-request", "audit"]
    }
  }
}
