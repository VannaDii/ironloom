{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DiscordCommandContractRegistry",
  "definitions": {
    "DiscordCommandContractRegistry": {
      "type": "object",
      "properties": {
        "version": {
          "const": 1
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "type": {
                "const": 1
              },
              "action": {
                "enum": [
                  "run-this",
                  "claim-this",
                  "approve-this",
                  "block-this",
                  "complete-this",
                  "pause-this",
                  "resume-this",
                  "rebase-all-dependents",
                  "retry-gates",
                  "merge-now",
                  "show-status",
                  "show-last-artifact",
                  "explain-failure",
                  "sync-worktree",
                  "release-worktree",
                  "update-spec"
                ]
              },
              "privileged": {
                "type": "boolean"
              }
            },
            "required": ["name", "description", "type", "action", "privileged"],
            "additionalProperties": false
          }
        }
      },
      "required": ["version", "contracts"],
      "additionalProperties": false
    }
  }
}
