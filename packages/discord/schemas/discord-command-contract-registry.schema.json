{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/DiscordCommandContractRegistry",
  "definitions": {
    "DiscordCommandContractRegistry": {
      "type": "object",
      "properties": {
        "version": {
          "const": 1
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "type": {
                "const": 1
              },
              "action": {
                "enum": [
                  "run-this",
                  "claim-this",
                  "approve-this",
                  "block-this",
                  "complete-this",
                  "pause-this",
                  "resume-this",
                  "rebase-all-dependents",
                  "retry-gates",
                  "merge-now",
                  "show-status",
                  "show-last-artifact",
                  "explain-failure",
                  "sync-worktree",
                  "release-worktree",
                  "update-spec",
                  "new-project",
                  "open-project",
                  "project-summary",
                  "project-settings",
                  "project-settings-history",
                  "cancel-project",
                  "resume-project",
                  "release-project",
                  "phase-contract",
                  "alternatives",
                  "redirect",
                  "consider",
                  "research",
                  "spec"
                ]
              },
              "privileged": {
                "type": "boolean"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "const": 3
                    },
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "choices": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "value": {
                            "type": "string"
                          }
                        },
                        "required": ["name", "value"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["type", "name", "description", "required"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["name", "description", "type", "action", "privileged"],
            "additionalProperties": false
          }
        }
      },
      "required": ["version", "contracts"],
      "additionalProperties": false
    }
  }
}
