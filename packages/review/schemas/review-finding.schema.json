{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ReviewFinding",
  "definitions": {
    "ReviewFinding": {
      "type": "object",
      "properties": {
        "findingId": {
          "type": "string"
        },
        "severity": {
          "enum": ["low", "medium", "high", "critical"]
        },
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "fixRecommendation": {
          "type": "string"
        },
        "blocking": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "string"
        },
        "source": {
          "enum": ["automated", "sonar", "human"]
        },
        "specConformance": {
          "type": "object",
          "properties": {
            "specId": {
              "type": "string"
            },
            "satisfiedCriteria": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missingCriteria": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["specId", "satisfiedCriteria", "missingCriteria"],
          "additionalProperties": false
        }
      },
      "required": [
        "findingId",
        "severity",
        "path",
        "message",
        "rationale",
        "fixRecommendation",
        "blocking",
        "updatedAt"
      ],
      "additionalProperties": false
    }
  }
}
