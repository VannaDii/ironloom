{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/MemoryEntry",
  "definitions": {
    "MemoryEntry": {
      "type": "object",
      "properties": {
        "memoryId": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/MemoryKind"
        },
        "subject": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "$ref": "#/definitions/MemoryStatus"
        },
        "sourceArtifactId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "memoryId",
        "kind",
        "subject",
        "detail",
        "tags",
        "status",
        "updatedAt"
      ],
      "additionalProperties": false
    },
    "MemoryKind": {
      "type": "string",
      "enum": ["decision", "constraint", "preference", "trap"]
    },
    "MemoryStatus": {
      "type": "string",
      "enum": ["active", "superseded"]
    }
  }
}
