{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/WorktreeAllocation",
  "definitions": {
    "WorktreeAllocation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "enum": [
            "draft",
            "queued",
            "claimed",
            "running",
            "review",
            "blocked",
            "approved",
            "merge-ready",
            "merged",
            "failed",
            "rebasing",
            "complete"
          ]
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "taskId": {
          "type": "string"
        },
        "branchName": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "branchSafety": {
          "type": "object",
          "properties": {
            "status": {
              "enum": ["safe", "blocked"]
            },
            "branchName": {
              "type": "string"
            },
            "normalizedBranchName": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "nextAction": {
              "type": "string"
            }
          },
          "required": [
            "status",
            "branchName",
            "normalizedBranchName",
            "reason",
            "nextAction"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "taskId",
        "branchName",
        "worktreePath"
      ],
      "additionalProperties": false
    }
  }
}
