{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/StoredRecordSchema",
  "definitions": {
    "StoredRecordSchema": {
      "$ref": "#/definitions/StoredRecord"
    },
    "StoredRecord": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/definitions/StoreScope"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/LifecycleStatus"
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string"
        },
        "layoutVersion": {
          "type": "number",
          "const": 1
        },
        "indexes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StoreIndexName"
          }
        },
        "payload": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "key",
        "scope",
        "summary",
        "status",
        "trace",
        "updatedAt",
        "payload"
      ],
      "additionalProperties": false
    },
    "StoreScope": {
      "type": "string",
      "enum": ["artifacts", "memory", "state", "telemetry"]
    },
    "LifecycleStatus": {
      "type": "string",
      "enum": [
        "draft",
        "queued",
        "claimed",
        "running",
        "review",
        "blocked",
        "approved",
        "merge-ready",
        "merged",
        "failed",
        "rebasing",
        "complete"
      ]
    },
    "StoreIndexName": {
      "type": "string",
      "enum": ["active-thread", "task", "pull-request", "branch", "artifact"]
    }
  }
}
