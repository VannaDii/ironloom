{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "customConditions": ["source"],
    "lib": ["ES2024"],
    "strict": true,
    "alwaysStrict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "useDefineForClassFields": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@vannadii/devplat-core": ["./packages/core/src/index.ts"],
      "@vannadii/devplat-config": ["./packages/config/src/index.ts"],
      "@vannadii/devplat-artifacts": ["./packages/artifacts/src/index.ts"],
      "@vannadii/devplat-memory": ["./packages/memory/src/index.ts"],
      "@vannadii/devplat-research": ["./packages/research/src/index.ts"],
      "@vannadii/devplat-specs": ["./packages/specs/src/index.ts"],
      "@vannadii/devplat-slicing": ["./packages/slicing/src/index.ts"],
      "@vannadii/devplat-queue": ["./packages/queue/src/index.ts"],
      "@vannadii/devplat-worktrees": ["./packages/worktrees/src/index.ts"],
      "@vannadii/devplat-execution": ["./packages/execution/src/index.ts"],
      "@vannadii/devplat-gates": ["./packages/gates/src/index.ts"],
      "@vannadii/devplat-sonarcloud": ["./packages/sonarcloud/src/index.ts"],
      "@vannadii/devplat-review": ["./packages/review/src/index.ts"],
      "@vannadii/devplat-remediation": ["./packages/remediation/src/index.ts"],
      "@vannadii/devplat-prs": ["./packages/prs/src/index.ts"],
      "@vannadii/devplat-branching": ["./packages/branching/src/index.ts"],
      "@vannadii/devplat-supervisor": ["./packages/supervisor/src/index.ts"],
      "@vannadii/devplat-observability": [
        "./packages/observability/src/index.ts"
      ],
      "@vannadii/devplat-github": ["./packages/github/src/index.ts"],
      "@vannadii/devplat-openclaw": ["./packages/openclaw/src/index.ts"],
      "@vannadii/devplat-discord": ["./packages/discord/src/index.ts"],
      "@vannadii/devplat-policy": ["./packages/policy/src/index.ts"],
      "@vannadii/devplat-storage": ["./packages/storage/src/index.ts"]
    }
  }
}
