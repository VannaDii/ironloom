{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "tag", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["create", "name"]
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      },
      "required": ["type", "port", "annotations"]
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "command": {
      "$ref": "#/definitions/stringArray"
    },
    "args": {
      "$ref": "#/definitions/stringArray"
    },
    "resources": {
      "$ref": "#/definitions/freeformObject"
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/freeformObject"
      }
    },
    "affinity": {
      "$ref": "#/definitions/freeformObject"
    },
    "env": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/freeformObject"
      }
    },
    "envFrom": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/freeformObject"
      }
    },
    "discordGateway": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "intents": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["enabled", "url", "intents"]
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["enabled", "mountPath", "data"],
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "data": {
                "required": ["openclaw.json"]
              }
            }
          }
        }
      ]
    },
    "secretRefs": {
      "$ref": "#/definitions/stringArray"
    },
    "configMapRefs": {
      "$ref": "#/definitions/stringArray"
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessModes": {
          "$ref": "#/definitions/stringArray"
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "enabled",
        "accessModes",
        "size",
        "storageClassName",
        "mountPath"
      ]
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/freeformObject"
      }
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/freeformObject"
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "paths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "ImplementationSpecific", "Prefix"]
                    }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/freeformObject"
          }
        }
      },
      "required": ["enabled", "className", "annotations", "hosts", "tls"]
    }
  },
  "required": [
    "replicaCount",
    "image",
    "serviceAccount",
    "podAnnotations",
    "podLabels",
    "service",
    "containerPort",
    "command",
    "args",
    "resources",
    "nodeSelector",
    "tolerations",
    "affinity",
    "env",
    "envFrom",
    "discordGateway",
    "config",
    "secretRefs",
    "configMapRefs",
    "persistence",
    "extraVolumeMounts",
    "extraVolumes",
    "ingress"
  ],
  "definitions": {
    "freeformObject": {
      "type": "object",
      "additionalProperties": true
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
