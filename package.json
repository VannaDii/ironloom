{
  "name": "devplat",
  "private": true,
  "version": "0.0.0",
  "description": "Discord-first autonomous development platform foundation.",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*",
    "site/guide-docs"
  ],
  "scripts": {
    "build:workspace": "turbo run build --output-logs=errors-only",
    "build": "npm run prepare:generated && npm run build:workspace",
    "act:ci": "sh scripts/run-act.sh ci",
    "act:cleanup": "sh scripts/run-act.sh cleanup",
    "act:pr": "sh scripts/run-act.sh pr",
    "act:typescript": "sh scripts/run-act.sh typescript",
    "changeset": "changeset",
    "check:changed-coverage": "node scripts/check-changed-coverage.mjs",
    "check:constants": "node scripts/check-constants.mjs",
    "check:dependency-graph": "node scripts/check-dependency-graph.mjs",
    "check:exports": "node scripts/check-exports.mjs",
    "check:instructions": "node scripts/check-instructions.mjs",
    "check:naming": "node scripts/check-naming.mjs",
    "check:openclaw-manifest": "node scripts/check-openclaw-manifest.mjs",
    "check:packages": "node scripts/check-packages.mjs",
    "check:policy-boundaries": "node scripts/check-policy-boundaries.mjs",
    "check:pre-commit": "node scripts/check-pre-commit.mjs",
    "check:pre-push": "node scripts/check-pre-push.mjs",
    "check:regex-governance": "node scripts/check-regex-governance.mjs",
    "check:repo": "npm run check:packages && npm run check:exports && npm run check:dependency-graph && npm run check:schemas && npm run check:openclaw-manifest && npm run check:instructions && npm run check:naming && npm run check:policy-boundaries && npm run check:constants && npm run check:regex-governance && npm run lint",
    "check:schemas": "node --import tsx --conditions=source scripts/check-schemas.mjs",
    "clean": "turbo run clean && rm -rf coverage .turbo",
    "docs:build": "vitepress build site/guide-docs",
    "docs:dev": "vitepress dev site/guide-docs",
    "docs:preview": "vitepress preview site/guide-docs",
    "dev:local-stack": "node --env-file=.env --import tsx --conditions=source scripts/openclaw-local-stack.mjs",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "generate:openclaw-manifest": "node scripts/generate-openclaw-manifest.mjs",
    "generate:schemas": "node --import tsx --conditions=source scripts/generate-schemas.mjs",
    "lint": "eslint . --max-warnings 0",
    "maintenance:headless": "node --import tsx --conditions=source scripts/headless-maintenance-runner.mjs",
    "preinstall": "node scripts/verify-node-version.mjs",
    "prepare:generated": "npm run generate:schemas && npm run generate:openclaw-manifest",
    "prepare": "husky",
    "release": "changeset publish",
    "release:tag-lines": "node scripts/tag-release-lines.mjs",
    "sonar:analyze:changed": "node scripts/sonarqube-cli-analyze-changed.mjs analyze",
    "sonar:install-cli": "node scripts/sonarqube-cli-analyze-changed.mjs install",
    "test:coverage:workspace": "node --conditions=source ./node_modules/vitest/vitest.mjs run --coverage",
    "test:coverage": "npm run prepare:generated && npm run test:coverage:workspace",
    "test:discord:ux:live-lab": "node scripts/discord-ux-live-lab.mjs",
    "test:discord:ux:live-lab:preflight": "vitest run scripts/discord-ux-live-lab.test.mjs",
    "test:openclaw:deep": "node scripts/openclaw-deep-test.mjs --mode hermetic",
    "test:openclaw:live-lab": "node scripts/openclaw-live-lab.mjs",
    "test:openclaw:live-lab:janitor:local": "node --env-file=.env scripts/openclaw-live-lab-janitor.mjs",
    "test:openclaw:live-lab:local": "node --env-file=.env scripts/openclaw-live-lab.mjs",
    "test:openclaw:live-lab:preflight": "vitest run scripts/openclaw-live-lab.test.mjs",
    "test:workspace": "turbo run test --output-logs=errors-only",
    "test": "npm run prepare:generated && npm run test:workspace",
    "typecheck:workspace": "turbo run typecheck --output-logs=errors-only",
    "typecheck": "npm run typecheck:workspace",
    "verify:node": "node scripts/verify-node-version.mjs",
    "verify:sonar-bootstrap": "tsx scripts/verify-sonar-bootstrap.ts",
    "version-packages": "changeset version && npm run prepare:generated"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@discordjs/opus": "file:tools/npm-overrides/discordjs-opus",
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-sonarjs": "4.0.3",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "node-domexception": "file:tools/npm-overrides/node-domexception",
    "prettier": "3.8.3",
    "semver": "7.7.4",
    "ts-json-schema-generator": "2.9.0",
    "tsx": "4.21.0",
    "turbo": "2.9.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.10",
    "vitepress": "1.6.4",
    "vitest": "4.1.5"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "hono": "4.12.14",
    "openclaw@2026.4.15": {
      "@modelcontextprotocol/sdk": {
        "@hono/node-server": "1.19.14",
        "hono": "4.12.14"
      },
      "hono": "npm:hono@4.12.14"
    }
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,mts,cts}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/devplat.git"
  },
  "bugs": {
    "url": "https://github.com/VannaDii/devplat/issues"
  },
  "homepage": "https://github.com/VannaDii/devplat#readme",
  "license": "MIT"
}
